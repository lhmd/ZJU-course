	//异步加载文本，onTextLoaded(strText/*失败为null*/)
	this.raiseLoadText=function(strURL,bCache,onTextLoaded)
	{
		var httpRequest=null;
		if(window.XMLHttpRequest)
		{ 
		    httpRequest	=new XMLHttpRequest();
		}
		else if(window.ActiveXObject)
		{
		    httpRequest	=new ActiveXObject("Microsoft.XMLHTTP");
		}
		if(onTextLoaded!=null && onTextLoaded!=undefined)
		{
			httpRequest.onreadystatechange=function()
			{
				if(httpRequest.readyState!=4)
				{
					return;
				}

				//执行结束
				if(httpRequest.status!=200 && httpRequest.status!=0)
				{//执行发生错误
					onTextLoaded(null);
					return;
				}

				//执行成功
				var strText=httpRequest.responseText;
				onTextLoaded(strText);
			}
		}

		//发送HTTP请求
		try
		{
			httpRequest.open('GET',strURL,true);
			httpRequest.setRequestHeader('Content-Type','application/x-www-form-urlencoded;charset=utf-8');
			if(!(bCache==true))
			{
				httpRequest.setRequestHeader('If-Modified-Since','0');
			}
			httpRequest.send(null);
		}
		catch(e)
		{
		}
	}

	//jsonp 回调
	this.jsonpCallback=function(strResult)
	{
		var cdoResult=new CDO();
		cdoResult.fromXMLText(strResult);
		var cdoReturn=cdoResult.getCDOValue("cdoReturn");
		var ret=new Return();
		ret.nCode=cdoReturn.getIntegerValue("nCode");
		ret.strInfo=cdoReturn.getStringValue("strInfo");
		ret.strText=cdoReturn.getStringValue("strText");
		
		var cdoResponse=cdoResult.getCDOValue("cdoResponse");
		var callBackName=cdoResponse.getStringValue("strCallBack");
		if(callBackName==null)
		{
			return;
		}
		
		for (var i in window)
		{ 
			if (i === callBackName) 
			{　　
				window[i](cdoResponse,ret);
				break;　　　　 
			}
		}　　
	}
	
	//jsonp执行事务
	this.jsonpTrans=function(cdoRequest,strServletURL,onTransHandled)
	{    
		var strServiceName=cdoRequest.getStringValue("strServiceName");
		var strTransName=cdoRequest.getStringValue("strTransName");
		cdoRequest.setBooleanValue("bJSONP",true);
		cdoRequest.setStringValue("strCallBack",onTransHandled);
		var strParameter="strServiceName="+strServiceName+"&strTransName="+strTransName;
		var strRequest = cdoRequest.toXML();
		var strURL = encodeURI(strServletURL+"?"+strParameter) + "&$$CDORequest$$=" + encodeURIComponent(strRequest);

		var ds = document.createElement('script');
		ds.type = 'text/javascript';
		ds.src = strURL;
		ds.charset = 'UTF-8';
		(document.getElementsByTagName('head')[0]).appendChild(ds);
	}

	
	var bHandlingTrans=false;
	//执行事务
	//bCache默认为false
	this.handleTrans=function(cdoRequest,cdoResponse,bCache)
	{
		if(bHandlingTrans==true)
		{
			return Return.valueOf(-1,"Please do not click frequently");
		}
		
		bHandlingTrans=true;
		
		var httpRequest=null;
		while(true)
		{
			if(window.XMLHttpRequest)
			{ 
				httpRequest	=new XMLHttpRequest();
			}
			else if(window.ActiveXObject)
			{
				httpRequest	=new ActiveXObject("Microsoft.XMLHTTP");
			}

			var strServiceName=cdoRequest.getStringValue("strServiceName");
			var strTransName=cdoRequest.getStringValue("strTransName");

			//发送HTTP请求
			var strParameter="strServiceName="+strServiceName+"&strTransName="+strTransName;
			try
			{
				var strRequest = cdoRequest.toXML();
				var strURL = encodeURI(this.strServletURL+"?"+strParameter) + "&$$CDORequest$$=" + encodeURIComponent(strRequest);
				//CDORequest生成的URL的串的长度,如果大于1KB,则走POST,否则走GET(URL最大长度为2048字符(2KB))
				if(strURL.length > 1024 || !(bCache==true))
				{
					httpRequest.open('POST',encodeURI(this.strServletURL+"?"+strParameter),false);
					httpRequest.setRequestHeader('Content-Type','application/x-www-form-urlencoded;charset=utf-8');
					httpRequest.send("$$CDORequest$$="+encodeURIComponent(strRequest));
				}
				else
				{
					httpRequest.open('GET',strURL,false);
					httpRequest.setRequestHeader('Content-Type','application/x-www-form-urlencoded;charset=utf-8');
					if(!(bCache==true))
					{
						httpRequest.setRequestHeader('If-Modified-Since','0');
					}
					httpRequest.send(null);
				}
			}
			catch(e)
			{
				bHandlingTrans=false;
				
				return null;
			}
			if(httpRequest.status==200 || httpRequest.status==0)
			{//成功
				break;
			}
			if(httpRequest.status>10000)
			{//浏览器异常，重试
				continue;
			}
			bHandlingTrans=false;
			
			//失败
			return null;
		}

		var ret=new Return();
		try
		{
			var nodes=httpRequest.responseXML.documentElement.childNodes;
	
			var cdoReturn=new CDO();
			cdoReturn.fromXML(nodes[0].childNodes[0]);
			if(nodes.length>1)
			{
				cdoResponse.fromXML(nodes[1].childNodes[0]);
			}
			
			ret.nCode=cdoReturn.getIntegerValue("nCode");
			ret.strInfo=cdoReturn.getStringValue("strInfo");
			ret.strText=cdoReturn.getStringValue("strText");
		}
		catch(e)
		{
			bHandlingTrans=false;
			
			return null;
		}
		bHandlingTrans=false;
		
		return ret;
	}

	//异步执行事务
	//onTransHandled=function(cdoResponse,ret)
	//bCache默认为false
	this.raiseTrans=function(cdoRequest,bCache,onTransHandled)
	{    
		var httpRequest=null;
		if(window.XMLHttpRequest)
		{ 
		    httpRequest	=new XMLHttpRequest();
		}
		else if(window.ActiveXObject)
		{
		    httpRequest	=new ActiveXObject("Microsoft.XMLHTTP");
		}
		if(onTransHandled!=null && onTransHandled!=undefined)
		{
			httpRequest.onreadystatechange=function()
			{
				if(httpRequest.readyState!=4)
				{
					return;
				}

				//执行结束
				if(httpRequest.status!=200 && httpRequest.status!=0)
				{//执行发生错误
					return;
				}

				//执行成功
				var cdoResponse=new CDO();
				var ret=new Return();
				try
				{
					var nodes=httpRequest.responseXML.documentElement.childNodes;
			
					var cdoReturn=new CDO();
					cdoReturn.fromXML(nodes[0].childNodes[0]);
					if(nodes.length>1)
					{
						cdoResponse.fromXML(nodes[1].childNodes[0]);
					}
					
					ret.nCode=cdoReturn.getIntegerValue("nCode");
					ret.strInfo=cdoReturn.getStringValue("strInfo");
					ret.strText=cdoReturn.getStringValue("strText");
				}
				catch(e)
				{
					return;
				}
				
				onTransHandled(cdoResponse,ret);
			}
		}

		var strServiceName=cdoRequest.getStringValue("strServiceName");
		var strTransName=cdoRequest.getStringValue("strTransName");

		//发送HTTP请求
		var strParameter="strServiceName="+strServiceName+"&strTransName="+strTransName;
		try
		{
			var strRequest = cdoRequest.toXML();
			var strURL = encodeURI(this.strServletURL+"?"+strParameter) + "&$$CDORequest$$=" + encodeURIComponent(strRequest);
			//CDORequest生成的URL的串的长度,如果大于1KB,则走POST,否则走GET(URL最大长度为2048字符(2KB))
			if(strURL.length > 1024 || !(bCache==true))
			{
				httpRequest.open('POST',encodeURI(this.strServletURL+"?"+strParameter),true);
				httpRequest.setRequestHeader('Content-Type','application/x-www-form-urlencoded;charset=utf-8');
				httpRequest.send("$$CDORequest$$="+encodeURIComponent(strRequest));
			}
			else
			{
				httpRequest.open('GET',strURL,true);
				httpRequest.setRequestHeader('Content-Type','application/x-www-form-urlencoded;charset=utf-8');
				if(!(bCache==true))
				{
					httpRequest.setRequestHeader('If-Modified-Since','0');
				}
				httpRequest.send(null);
			}
		}
		catch(e)
		{
		}
	}

	//定义事件
	this.onVerifyFailed=null;
}

