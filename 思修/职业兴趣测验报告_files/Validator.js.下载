	if (c.test(a) == true)
		return false;
	var b = /^(([a-zA-Z0-9]{0,20}\.)*)([a-zA-Z0-9]{1,20}\.)((com)|(edu)|(net)|(org)|(gov)|(cn)|(cc)|(tv)|(asia)|(info)|(biz)|(hk)|(tw)|(me)|(us)|(ph)|(cd)|(tel)|(name)|(so)|(mobi)|(com\.cn)|(edu\.cn)|(net\.cn)|(org\.cn)|(gov\.cn)|(com\.tw)|(org\.tw)|(idv\.tw)|(com\.hk))$/;
