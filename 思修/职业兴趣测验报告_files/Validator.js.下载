function isNumber(a) {
	if (a == null || a == undefined || a.length == 0)
		return false;
	for ( var b = 0; b < a.length; b++)
		if (a.charAt(b) < "0" || a.charAt(b) > "9")
			return false;
	return true
}
function isEmail(a) {
	var b = /^[-_A-Za-z0-9]+@([_A-Za-z0-9]+\.)+[A-Za-z0-9]{2,3}$/;
	if (b.test(a) == true)
		return true;
	else
		return false
}
function isMobile(a) {
	var b = /(13|14|15|16|17|18|19)\d{9}/;
	if (b.test(a) == true)
		return true;
	else
		return false
}
